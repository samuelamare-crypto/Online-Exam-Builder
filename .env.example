# Supabase project credentials (required — the app has no working backend
# without these). Find them in your Supabase project: Settings → API.
# The anon key is safe to expose client-side; every table it can touch is
# locked down by Row Level Security (see supabase/migrations/0001_init.sql).
VITE_SUPABASE_URL=https://fmgixrytiprlknuddchn.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZtZ2l4cnl0aXBybGtudWRkY2huIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3OTk2OTksImV4cCI6MjA5ODM3NTY5OX0.v34W0RdPSiMCLYtcd1k23O04mpyTJMLHkVEWR1nhcYA
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_kHwkpG9RH6z6w9ZpiWLtzg_t_iAlKly
# Required for DOCX/PDF question import (AI-powered question extraction).
#
# Without this set, the JSON and CSV import options on the admin Import
# page still work fully — only the "upload a Word/PDF document and let AI
# read it" feature needs this key.
#
# In Lovable: Project Settings → Secrets → Add Secret, key ANTHROPIC_API_KEY
# Self-hosting (Cloudflare/Vercel/Node/etc.): set this as a real environment
# variable / secret on your platform — copying it into a committed .env file
# is fine for local dev only, never commit a real key.
#
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: your production domain. Used by /sitemap.xml to generate absolute
# URLs for search-engine crawlers. No trailing slash.
# Without this set, sitemap URLs are relative paths (valid but not preferred).
# VITE_SITE_URL=https://quizpoll.example.com
