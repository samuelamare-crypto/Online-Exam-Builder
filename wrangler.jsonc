{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "online-exam-builder",
  "compatibility_date": "2026-07-07",
  "observability": {
    "enabled": true
  },
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
